rules_version = '2'

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Admins by email (must be authenticated with these emails)
    function isAdmin() {
      return isSignedIn() && request.auth.token.email in [
        'ti.emporioarouca@gmail.com',
        'renan@gmail.com',
      ];
    }

    // Users can read/write their own profile doc
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Produtos: leitura liberada; escrita só para admin
    match /produtos/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Categorias: leitura liberada; escrita só para admin
    match /categorias/{categoriaId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Fallback: deny anything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
